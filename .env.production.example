# Certior production environment template
#
# Safe GitHub practice:
# - keep this file committed only as a placeholder template
# - copy the values into your secret manager or deployment platform
# - do not rename this file to .env.production inside the repository
# - do not commit real keys, DSNs, certificates, or private key files

CERTIOR_ENV=production
CERTIOR_HOST=0.0.0.0
CERTIOR_PORT=8000
CERTIOR_STUDIO_URL=https://studio.example.com
CERTIOR_LLM_PROVIDER=openai

# Required: JWT signing secret for capability tokens. The server refuses
# to start in non-development environments without this. Generate one:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# Store the value in your secret manager and inject at deploy time.
CERTIOR_KMS_ROOT_SECRET=

# Required: API key set, as a JSON object mapping API key -> client label.
# The server refuses to start in non-development environments without this.
# Example: CERTIOR_API_KEYS_JSON='{"ck-prod-...": "orchestrator-a", ...}'
# Generate a key with: python -c "import secrets; print('ck-' + secrets.token_urlsafe(32))"
CERTIOR_API_KEYS_JSON=

# Store the real value in your secret manager or process manager.
OPENAI_API_KEY=

# Use a dedicated least-privilege database role and require TLS.
DATABASE_URL=postgresql://certior_app:<url-encoded-password>@db.example.com:5432/certior?sslmode=require&application_name=certior-api

# Optional background queue.
REDIS_URL=redis://redis.example.com:6379/0

# Point to the built Lean verifier in deployment.
CERTIOR_FLOW_CHECK_BINARY=/opt/certior/lean4/CertiorPlan/.lake/build/bin/certior-flow-check

# Optional observability.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4317