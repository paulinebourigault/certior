# Certior Environment Configuration
# Copy to .env and edit, or set in your shell.
# See CONFIGURATION.md for full documentation.

# ── LLM (required for agent mode) ────────────────────────────────────
# For production, inject these through your secrets system or process manager.
# Do not commit real keys or rely on a long-lived shared shell session.
# Get Anthropic keys at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Get OpenAI keys at https://platform.openai.com
OPENAI_API_KEY=
# Optional explicit override when multiple providers are configured.
# CERTIOR_LLM_PROVIDER=openai

# ── Server ────────────────────────────────────────────────────────────
CERTIOR_HOST=127.0.0.1
CERTIOR_PORT=8000
CERTIOR_ENV=development

# ── Auth (required when CERTIOR_ENV != development) ──────────────────
# JWT signing secret for capability tokens. In development the server
# generates a fresh per-process value if this is unset (tokens issued
# in one process cannot be verified by another). Production deployments
# must set this explicitly. Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# CERTIOR_KMS_ROOT_SECRET=

# API key set for the FastAPI server, as a JSON object mapping
# API key -> human-readable client label. In development the variable
# may be unset; in that case CERTIOR_DEV_API_KEY (set by run.sh) is
# accepted instead so the orchestrator-facing routes work out of the
# box. Production deployments must set CERTIOR_API_KEYS_JSON. Example:
#     CERTIOR_API_KEYS_JSON='{"ck-abc123...": "internal-orchestrator"}'
# CERTIOR_API_KEYS_JSON=

# ── Storage ───────────────────────────────────────────────────────────
# Directory for file tool operations (agents read/write here)
CERTIOR_WORKSPACE=./.workspace

# PostgreSQL (production - preferred over SQLite)
# DATABASE_URL=postgresql://certior:certior@localhost:5432/certior

# Redis (production - Celery task queue)
# REDIS_URL=redis://localhost:6379/0

# SQLite fallback (single-node development - used when DATABASE_URL not set)
CERTIOR_DATA_DIR=./.data

# ── Observability (optional) ──────────────────────────────────────────
# Uncomment to export traces to an OpenTelemetry collector
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
